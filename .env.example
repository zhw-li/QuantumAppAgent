# TYQA — cp .env.example .env && fill in your keys

# LLM provider (pick at least one)
ANTHROPIC_API_KEY=           # console.anthropic.com
OPENAI_API_KEY=              # platform.openai.com
GOOGLE_API_KEY=              # aistudio.google.com/api-keys
NVIDIA_API_KEY=              # build.nvidia.com

# Direct providers (optional)
MINIMAX_API_KEY=              # platform.minimaxi.com (China, default) or platform.minimax.io (Global)
MINIMAX_BASE_URL=             # https://api.minimaxi.com/anthropic (default) or https://api.minimax.io/anthropic
ZHIPU_API_KEY=                # open.bigmodel.cn (智谱)
VOLCENGINE_API_KEY=           # volcengine.com (火山引擎)
DASHSCOPE_API_KEY=            # dashscope.aliyuncs.com (阿里云)
MOONSHOT_API_KEY=             # platform.moonshot.cn (月之暗面)
KIMI_API_KEY=                 # kimi.com/code (Kimi 代码计划)

# Aggregator platforms (optional)
SILICONFLOW_API_KEY=          # siliconflow.cn
OPENROUTER_API_KEY=           # openrouter.ai

# Custom endpoints (optional)
CUSTOM_OPENAI_API_KEY=       # OpenAI-compatible endpoint
CUSTOM_OPENAI_BASE_URL=
CUSTOM_ANTHROPIC_API_KEY=    # Anthropic-compatible endpoint
CUSTOM_ANTHROPIC_BASE_URL=

# Local models (optional)
OLLAMA_BASE_URL=              # http://localhost:11434 (default)

# Web search (optional)
TAVILY_API_KEY=              # app.tavily.com
